# Sensitive config
.env
.env.*
!.env.example
*.key
*.pem
native-host/manifest/eastmoney-ai-sync-installed.json
.claude/settings.local.json

# Evaluation data + budget + drafts (contains private info, never commit)
.eastmoney-ai/
data/frozen-eval-*.json

# Model weights (large files + potential license issues)
kronos/*.pt
kronos/*.safetensors
lib/lstm/*.pt
*.onnx

# Dependencies
node_modules/
package-lock.json.bak

# Tests / temp files
.eval-cache/
*.test.local.js
tmp_*.js
_test_*.js
v*-eval.js
v*-verify-eval.js
v*-verify.js
v*-full.js

# Logs
logs/
*.log

# System files
.DS_Store
Thumbs.db

# Chrome extension forbids _ prefix filenames
_*
=

# Kronos venv (rebuildable)
kronos/venv/

# IDE config
.vscode/
.idea/
*.swp
kronos/weights/
temp_scripts/
skills-lock.json
